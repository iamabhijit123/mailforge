# ──────────────────────────────────────────────────────────────────
# MailForge — Environment Variables
# Copy this file to .env.local and fill in your real values.
# .env.local is never committed to git (secrets stay local).
# ──────────────────────────────────────────────────────────────────

# Optional: JWT secret for signing auth tokens
# Leave blank to auto-generate on first run (not stable across restarts)
JWT_SECRET=change-this-to-a-random-secret-at-least-32-chars

# Optional: Anthropic API key for the AI Template Maker
# You can also enter this inside the app at Settings → AI Template Maker
# ANTHROPIC_API_KEY=sk-ant-...

# App URL (used for webhook links shown in Settings)
NEXT_PUBLIC_APP_URL=http://localhost:3000
